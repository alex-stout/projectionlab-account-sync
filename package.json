{
  "name": "projectionlab-account-sync",
  "description": "Browser extension to sync brokerage account balances into ProjectionLab",
  "private": true,
  "version": "0.4.3",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "mock-sites": "vite e2e/mock-sites --port 3000",
    "build:e2e": "E2E=true wxt build",
    "e2e": "npm run build:e2e && playwright test",
    "e2e:ci": "CI=true npm run build:e2e && CI=true playwright test",
    "docs:screenshots": "npm run build:e2e && SCREENSHOTS=true playwright test screenshots",
    "lint:firefox": "npm run build:firefox && addons-linter --self-hosted .output/firefox-mv3",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "@wxt-dev/module-react": "^1.1.5",
    "addons-linter": "^10.3.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "wxt": "^0.20.22"
  }
}
